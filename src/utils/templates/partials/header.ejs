<tr>
	<td
		align="center"
		style="
			background: #46b5e0;
			background: linear-gradient(90deg, #46b5e0 0%, #5795c7 100%);
			padding: 40px 20px;
		"
	>
		<h1
			style="
				margin: 0;
				font-family: 'Segoe UI', Arial, sans-serif;
				color: #ffffff;
				font-size: 24px;
				font-weight: 600;
			"
		>
			Добро пожаловать в Donation
		</h1>
		<p
			style="
				margin: 10px 0 0 0;
				font-family: 'Segoe UI', Arial, sans-serif;
				color: #e0f4ff;
				font-size: 16px;
			"
		>
			<%= title %>
		</p>
	</td>
</tr>
